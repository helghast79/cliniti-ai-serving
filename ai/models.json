    {
        "id": "prostate_whole_gland",
        "name": "Prostate Whole Gland Segmentation",
        "version": "0.1",
        "releaseDate": "2023-12-11",
        "requirements": [
            "1 MRI T2w series"
        ],
        "frontend":[
            {"id": "seriesT2", "type": "series", "label": "T2 MRI", "required": true}
        ],
        "output":[
	        {"id":"segT2", "type": "uploadSeg", "fileType": "dcm", "target":"seriesT2"},
            {"id":"cancerResult", "type": "object"}
        ],
        "command": [
            {"value": "python", "type": "fixed"},
            {"value": "/srv/cliniti/cliniti-ai-inference/ai/entrypoint-with-docker.py", "type": "fixed"},
            {"value": "-i", "type": "fixed"},
            {"value": "inputs/seriesT2", "type": "relativePath"},
            {"value": "-m", "type": "fixed"},
            {"value": "/srv/models/nnunet/nnunet_docker/models/prostate_whole_gland_model", "type": "fixed"},
            {"value": "-o", "type": "fixed"},
            {"value": "output", "type": "relativePath"},
            {"value": "-M", "type": "fixed"},
            {"value": "/srv/models/nnunet/nnunet_docker/metadata_templates/whole-prostate.json", "type": "fixed"},
            {"value": "-f", "type": "fixed"},
            {"type": "input", "ref":"folds", "default":"2"},
            {"value": "-t", "type": "fixed"},
            {"value": "-D", "type": "fixed"}
        ],
        "response": [
            {"id": "cancerResult", "type": "object", "file": "output.json"},
            {"type": "uploadSeg", "fileType": "dcm"}        
        ]
    },
    {
        "id": "prostate_ac1",
        "name": "Clinical significance disease model",
        "version": "0.1",
        "releaseDate": "2024-02-07",
        "requirements": [
            "1 MRI T2w series",
            "1 ADC series",
            "1 DWI series"
        ],
        "frontend":[
            {"id": "seriesT2", "type": "series", "label": "T2 MRI", "required": true},
            {"id": "seriesADC", "type": "series", "label": "ADC", "required": true},
            {"id": "seriesDWI", "type": "series", "label": "DWI", "required": true},
            {"id": "psa", "type": "number", "label": "PSA", "required": false}
        ],
        "output":[
            {"id":"cancerResult", "type": "object"},
            {"id":"segT2", "type": "uploadSeg", "fileType": "dcm", "target":"seriesT2"}
        ],
        "command": [
            {"value": "docker", "type": "fixed"},
	        {"value": "run", "type": "fixed"},
            {"value": "--gpus", "type": "fixed"},
            {"value": "all", "type": "fixed"},
	        {"value": "--rm", "type": "fixed"},
            {"value": "-v", "type": "fixed"},
            {"value": "/srv/:/data/", "type": "fixed"},
            {"value": "gland_aggressiveness_prediction:1.3", "type": "fixed"},
	        {"value": "-i", "type": "fixed"},
	        {"value":"inputs", "type": "relativePath"},
	        {"value": "-d", "type": "fixed"},
	        {"value": "-o", "type": "fixed"},
            {"value":"output", "type": "relativePath"}
        ],
        "response": [
	        {"id": "cancerResult", "type": "object", "file": "predictions.json"},
            {"id": "segT2", "type": "uploadSeg", "fileType": "dcm"}
        ]
    }
]
